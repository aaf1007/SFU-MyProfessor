{
    "manifest_version": 3,
    "name": "SFU ProfessorView",
    "version": "1.0.0",
    "description": "See Rate My Professor ratings directly in your SFU course schedule.",
    "permissions": ["storage"],
    "host_permissions": [
        "https://*.ratemyprofessors.com/*",
        "https://myschedule.erp.sfu.ca/*"
    ],
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": ["https://myschedule.erp.sfu.ca/*"],
            "js": ["content.js"],
            "css": ["content.css"],
            "run_at": "document_end"
        }
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self'"
    }
}